<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bitácora — panel de suscripciones</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #12151A;
    --surface: #1B1F27;
    --surface-hover: #232833;
    --border: #2A2F3A;
    --text: #E4E7EC;
    --text-muted: #8B93A1;
    --accent: #5EA8A0;
    --accent-dim: #3D7A74;
    --gold: #D9A441;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{height:100%;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'IBM Plex Sans', sans-serif;
    display:flex;
    min-height:100vh;
  }
  a{color:inherit; text-decoration:none;}

  #sidebar{
    width:280px;
    flex-shrink:0;
    background:var(--surface);
    border-right:1px solid var(--border);
    padding:28px 0;
    overflow-y:auto;
    height:100vh;
    position:sticky;
    top:0;
  }
  #brand{
    padding:0 24px 20px 24px;
    border-bottom:1px solid var(--border);
    margin-bottom:16px;
  }
  #brand h1{
    font-family:'Fraunces', serif;
    font-optical-sizing:auto;
    font-weight:600;
    font-size:1.6rem;
    letter-spacing:-0.01em;
  }
  #signal{
    display:flex;
    align-items:center;
    gap:8px;
    margin-top:10px;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    color:var(--text-muted);
  }
  .pulse{
    width:7px; height:7px; border-radius:50%;
    background:var(--accent);
    box-shadow:0 0 0 0 rgba(94,168,160,0.6);
    animation:pulse 2.4s infinite;
    flex-shrink:0;
  }
  @keyframes pulse{
    0%{box-shadow:0 0 0 0 rgba(94,168,160,0.55);}
    70%{box-shadow:0 0 0 7px rgba(94,168,160,0);}
    100%{box-shadow:0 0 0 0 rgba(94,168,160,0);}
  }
  nav ul{list-style:none;}
  .cat-btn{
    display:flex;
    justify-content:space-between;
    align-items:center;
    width:100%;
    text-align:left;
    padding:9px 24px;
    background:none;
    border:none;
    color:var(--text-muted);
    font-family:'IBM Plex Sans', sans-serif;
    font-size:0.86rem;
    cursor:pointer;
    border-left:3px solid transparent;
    transition:background 0.12s, color 0.12s;
  }
  .cat-btn:hover{ background:var(--surface-hover); color:var(--text); }
  .cat-btn.active{
    color:var(--text);
    background:var(--surface-hover);
    border-left:3px solid var(--accent);
    font-weight:500;
  }
  .cat-count{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    color:var(--text-muted);
    background:rgba(255,255,255,0.04);
    padding:1px 7px;
    border-radius:10px;
  }

  #main{ flex:1; padding:32px 40px; max-width:900px; }

  .panel-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
    padding-bottom:14px;
    border-bottom:1px solid var(--border);
    flex-wrap:wrap;
    gap:10px;
  }
  .panel-header h2{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.5rem;
  }
  .subtabs{ display:flex; gap:6px; }
  .subtab-btn{
    font-family:'IBM Plex Sans', sans-serif;
    font-size:0.8rem;
    color:var(--text-muted);
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:6px;
    padding:6px 12px;
    cursor:pointer;
    display:flex;
    align-items:center;
    gap:6px;
    transition:background 0.12s, color 0.12s, border-color 0.12s;
  }
  .subtab-btn .count{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    opacity:0.8;
  }
  .subtab-btn:hover{ color:var(--text); border-color:var(--accent-dim); }
  .subtab-btn.active{
    color:var(--bg);
    background:var(--accent);
    border-color:var(--accent);
    font-weight:500;
  }
  .subpanel{ display:none; }
  .subpanel.active{ display:block; animation:fadein 0.2s ease; }
  @keyframes fadein{ from{opacity:0; transform:translateY(4px);} to{opacity:1; transform:translateY(0);} }

  .video-row{
    display:flex;
    gap:16px;
    padding:14px 0;
    border-bottom:1px solid var(--border);
  }
  .video-row:hover .video-title{ color:var(--accent); }
  .thumb{
    width:160px;
    height:90px;
    flex-shrink:0;
    border-radius:6px;
    object-fit:cover;
    background:var(--surface-hover);
  }
  .video-meta{ flex:1; min-width:0; }
  .video-title{
    display:block;
    font-size:0.98rem;
    font-weight:500;
    line-height:1.35;
    margin-bottom:6px;
    transition:color 0.12s;
  }
  .video-sub{
    display:flex;
    gap:10px;
    align-items:center;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.74rem;
    color:var(--text-muted);
  }
  .video-sub .channel{ color:var(--gold); }

  .channel-list{
    list-style:none;
    columns:2;
    column-gap:32px;
  }
  .channel-list li{
    break-inside:avoid;
    padding:7px 0;
    border-bottom:1px solid var(--border);
    font-size:0.88rem;
  }
  .channel-list a:hover{ color:var(--accent); }
  .channel-item{ display:flex; align-items:center; gap:9px; }
  .channel-logo{
    width:22px; height:22px;
    border-radius:50%;
    object-fit:cover;
    flex-shrink:0;
    background:var(--surface-hover);
  }
  .channel-logo-fallback{
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    color:var(--text-muted);
    border:1px solid var(--border);
  }
  .new-marker{
    color:var(--gold);
    font-weight:700;
    margin-left:4px;
    font-size:1rem;
  }
  .empty, .loading{
    color:var(--text-muted);
    font-size:0.9rem;
    padding:20px 0;
  }

  ::-webkit-scrollbar{ width:8px; }
  ::-webkit-scrollbar-thumb{ background:var(--border); border-radius:4px; }

  @media (max-width: 800px){
    body{ flex-direction:column; }
    #sidebar{ width:100%; height:auto; position:relative; border-right:none; border-bottom:1px solid var(--border); }
    #main{ padding:24px; }
    .thumb{ width:110px; height:62px; }
  }
  @media (max-width: 600px){
    .channel-list{ columns:1; }
  }
</style>
</head>
<body>

<aside id="sidebar">
  <div id="brand">
    <h1>Bitácora</h1>
    <div id="signal">
      <span class="pulse"></span>
      última señal: {{ generated_at }}
    </div>
  </div>
  <nav>
    <ul id="cat-list">
      {% for cat in category_meta %}
      <li>
        <button class="cat-btn{% if loop.first %} active{% endif %}"
                data-slug="{{ cat.slug }}" data-name="{{ cat.name }}"
                data-videocount="{{ cat.video_count }}" data-channelcount="{{ cat.channel_count }}">
          <span>{{ cat.name }}</span>
          <span class="cat-count">{{ cat.channel_count }}</span>
        </button>
      </li>
      {% endfor %}
    </ul>
  </nav>
</aside>

<main id="main">
  <div class="panel-header">
    <h2 id="current-cat-name"></h2>
    <div class="subtabs">
      <button class="subtab-btn active" data-view="videos">Videos <span class="count" id="videos-count"></span></button>
      <button class="subtab-btn" data-view="canales">Canales <span class="count" id="canales-count"></span></button>
    </div>
  </div>

  {% if first_run %}
  <p class="empty" style="margin-bottom:12px;">Esta es la primera ejecución — todavía no hay una comparación anterior para saber qué canales subieron algo nuevo. Eso empezará a verse desde la próxima actualización.</p>
  {% endif %}

  <div class="subpanel active" id="view-videos"><p class="loading">Cargando…</p></div>
  <div class="subpanel" id="view-canales"><p class="loading">Cargando…</p></div>
</main>

<script>
  const cache = {};

  function renderVideos(videos) {
    if (!videos.length) return '<p class="empty">Sin videos recientes en esta categoría.</p>';
    return videos.map(v => `
      <a class="video-row" href="${v.link}" target="_blank" rel="noopener">
        ${v.thumbnail ? `<img class="thumb" src="${v.thumbnail}" alt="" loading="lazy">` : `<div class="thumb"></div>`}
        <div class="video-meta">
          <span class="video-title">${v.title}</span>
          <div class="video-sub">
            <span class="channel">${v.channel}</span>
            <span>·</span>
            <span>${v.published_display}</span>
          </div>
        </div>
      </a>`).join('');
  }

  function renderChannels(channels) {
    if (!channels.length) return '<p class="empty">No hay canales asignados a esta categoría.</p>';
    const items = channels.map(c => `
      <li>
        <span class="channel-item">
          ${c.logo
            ? `<img class="channel-logo" src="${c.logo}" alt="" loading="lazy">`
            : `<span class="channel-logo channel-logo-fallback">${c.title.charAt(0).toUpperCase()}</span>`}
          <a href="${c.url}" target="_blank" rel="noopener">${c.title}</a>${c.is_new ? `<span class="new-marker" title="Subió contenido nuevo desde la última actualización">*</span>` : ''}
        </span>
      </li>`).join('');
    return `<ul class="channel-list">${items}</ul>`;
  }

  async function loadCategory(slug, name, videoCount, channelCount) {
    document.getElementById('current-cat-name').textContent = name;
    document.getElementById('videos-count').textContent = videoCount;
    document.getElementById('canales-count').textContent = channelCount;

    if (cache[slug]) {
      renderInto(cache[slug]);
      return;
    }
    document.getElementById('view-videos').innerHTML = '<p class="loading">Cargando…</p>';
    document.getElementById('view-canales').innerHTML = '<p class="loading">Cargando…</p>';
    try {
      const resp = await fetch(`data/${slug}.json`);
      const data = await resp.json();
      cache[slug] = data;
      renderInto(data);
    } catch (e) {
      document.getElementById('view-videos').innerHTML = '<p class="empty">No se pudo cargar esta categoría.</p>';
    }
  }

  function renderInto(data) {
    document.getElementById('view-videos').innerHTML = renderVideos(data.videos);
    document.getElementById('view-canales').innerHTML = renderChannels(data.channels);
  }

  const catButtons = document.querySelectorAll('.cat-btn');
  catButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      catButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      loadCategory(btn.dataset.slug, btn.dataset.name, btn.dataset.videocount, btn.dataset.channelcount);
      window.scrollTo({top:0, behavior:'instant'});
    });
  });

  const subtabButtons = document.querySelectorAll('.subtab-btn');
  subtabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      subtabButtons.forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.subpanel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(`view-${btn.dataset.view}`).classList.add('active');
    });
  });

  // cargar la primera categoría automáticamente al abrir la página
  const firstBtn = document.querySelector('.cat-btn');
  if (firstBtn) {
    loadCategory(firstBtn.dataset.slug, firstBtn.dataset.name, firstBtn.dataset.videocount, firstBtn.dataset.channelcount);
  }
</script>

</body>
</html>
