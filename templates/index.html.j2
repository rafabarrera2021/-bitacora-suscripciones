<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bitácora — panel de suscripciones</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #12151A;
    --surface: #1B1F27;
    --surface-hover: #232833;
    --border: #2A2F3A;
    --text: #E4E7EC;
    --text-muted: #8B93A1;
    --accent: #5EA8A0;
    --accent-dim: #3D7A74;
    --gold: #D9A441;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{height:100%;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'IBM Plex Sans', sans-serif;
    display:flex;
    min-height:100vh;
  }
  a{color:inherit; text-decoration:none;}

  /* --- barra lateral --- */
  #sidebar{
    width:280px;
    flex-shrink:0;
    background:var(--surface);
    border-right:1px solid var(--border);
    padding:28px 0;
    overflow-y:auto;
    height:100vh;
    position:sticky;
    top:0;
  }
  #brand{
    padding:0 24px 20px 24px;
    border-bottom:1px solid var(--border);
    margin-bottom:16px;
  }
  #brand h1{
    font-family:'Fraunces', serif;
    font-optical-sizing:auto;
    font-weight:600;
    font-size:1.6rem;
    letter-spacing:-0.01em;
  }
  #signal{
    display:flex;
    align-items:center;
    gap:8px;
    margin-top:10px;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    color:var(--text-muted);
  }
  .pulse{
    width:7px; height:7px; border-radius:50%;
    background:var(--accent);
    box-shadow:0 0 0 0 rgba(94,168,160,0.6);
    animation:pulse 2.4s infinite;
    flex-shrink:0;
  }
  @keyframes pulse{
    0%{box-shadow:0 0 0 0 rgba(94,168,160,0.55);}
    70%{box-shadow:0 0 0 7px rgba(94,168,160,0);}
    100%{box-shadow:0 0 0 0 rgba(94,168,160,0);}
  }
  nav ul{list-style:none;}
  nav li{padding:0;}
  .cat-btn{
    display:flex;
    justify-content:space-between;
    align-items:center;
    width:100%;
    text-align:left;
    padding:9px 24px;
    background:none;
    border:none;
    color:var(--text-muted);
    font-family:'IBM Plex Sans', sans-serif;
    font-size:0.86rem;
    cursor:pointer;
    border-left:3px solid transparent;
    transition:background 0.12s, color 0.12s;
  }
  .cat-btn:hover{ background:var(--surface-hover); color:var(--text); }
  .cat-btn.active{
    color:var(--text);
    background:var(--surface-hover);
    border-left:3px solid var(--accent);
    font-weight:500;
  }
  .cat-count{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    color:var(--text-muted);
    background:rgba(255,255,255,0.04);
    padding:1px 7px;
    border-radius:10px;
  }

  /* --- panel principal --- */
  #main{ flex:1; padding:32px 40px; max-width:900px; }
  .panel{ display:none; }
  .panel.active{ display:block; animation:fadein 0.2s ease; }
  @keyframes fadein{ from{opacity:0; transform:translateY(4px);} to{opacity:1; transform:translateY(0);} }

  .panel-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
    padding-bottom:14px;
    border-bottom:1px solid var(--border);
    flex-wrap:wrap;
    gap:10px;
  }
  .panel-header h2{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.5rem;
  }
  .subtabs{ display:flex; gap:6px; }
  .subtab-btn{
    font-family:'IBM Plex Sans', sans-serif;
    font-size:0.8rem;
    color:var(--text-muted);
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:6px;
    padding:6px 12px;
    cursor:pointer;
    display:flex;
    align-items:center;
    gap:6px;
    transition:background 0.12s, color 0.12s, border-color 0.12s;
  }
  .subtab-btn .count{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    opacity:0.8;
  }
  .subtab-btn:hover{ color:var(--text); border-color:var(--accent-dim); }
  .subtab-btn.active{
    color:var(--bg);
    background:var(--accent);
    border-color:var(--accent);
    font-weight:500;
  }
  .subpanel{ display:none; }
  .subpanel.active{ display:block; animation:fadein 0.2s ease; }

  .channel-list{
    list-style:none;
    columns:2;
    column-gap:32px;
  }
  .channel-list li{
    break-inside:avoid;
    padding:7px 0;
    border-bottom:1px solid var(--border);
    font-size:0.88rem;
  }
  .channel-list a:hover{ color:var(--accent); }
  .channel-item{ display:flex; align-items:center; gap:9px; }
  .channel-logo{
    width:22px; height:22px;
    border-radius:50%;
    object-fit:cover;
    flex-shrink:0;
    background:var(--surface-hover);
  }
  .channel-logo-fallback{
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    color:var(--text-muted);
    border:1px solid var(--border);
  }
  .new-marker{
    color:var(--gold);
    font-weight:700;
    margin-left:4px;
    font-size:1rem;
  }
  @media (max-width: 600px){
    .channel-list{ columns:1; }
  }

  .video-row{
    display:flex;
    gap:16px;
    padding:14px 0;
    border-bottom:1px solid var(--border);
  }
  .video-row:hover .video-title{ color:var(--accent); }
  .thumb{
    width:160px;
    height:90px;
    flex-shrink:0;
    border-radius:6px;
    object-fit:cover;
    background:var(--surface-hover);
  }
  .video-meta{ flex:1; min-width:0; }
  .video-title{
    display:block;
    font-size:0.98rem;
    font-weight:500;
    line-height:1.35;
    margin-bottom:6px;
    transition:color 0.12s;
  }
  .video-sub{
    display:flex;
    gap:10px;
    align-items:center;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.74rem;
    color:var(--text-muted);
  }
  .video-sub .channel{ color:var(--gold); }

  .empty{
    color:var(--text-muted);
    font-size:0.9rem;
    padding:20px 0;
  }

  ::-webkit-scrollbar{ width:8px; }
  ::-webkit-scrollbar-thumb{ background:var(--border); border-radius:4px; }

  @media (max-width: 800px){
    body{ flex-direction:column; }
    #sidebar{ width:100%; height:auto; position:relative; border-right:none; border-bottom:1px solid var(--border); }
    #main{ padding:24px; }
    .thumb{ width:110px; height:62px; }
  }
</style>
</head>
<body>

<aside id="sidebar">
  <div id="brand">
    <h1>Bitácora</h1>
    <div id="signal">
      <span class="pulse"></span>
      última señal: {{ generated_at }}
    </div>
  </div>
  <nav>
    <ul>
      {% for cat in category_order %}
      <li>
        <button class="cat-btn{% if loop.first %} active{% endif %}" data-target="cat-{{ loop.index }}">
          <span>{{ cat }}</span>
          <span class="cat-count">{{ channels_by_category.get(cat, [])|length }}</span>
        </button>
      </li>
      {% endfor %}
    </ul>
  </nav>
</aside>

<main id="main">
  {% for cat in category_order %}
  <section class="panel{% if loop.first %} active{% endif %}" id="cat-{{ loop.index }}">
    <div class="panel-header">
      <h2>{{ cat }}</h2>
      <div class="subtabs">
        <button class="subtab-btn active" data-subtarget="cat-{{ loop.index }}-videos">Videos <span class="count">{{ categories[cat]|length }}</span></button>
        <button class="subtab-btn" data-subtarget="cat-{{ loop.index }}-canales">Canales <span class="count">{{ channels_by_category.get(cat, [])|length }}</span></button>
      </div>
    </div>

    <div class="subpanel active" id="cat-{{ loop.index }}-videos">
    {% if categories[cat] %}
      {% for v in categories[cat] %}
      <a class="video-row" href="{{ v.link }}" target="_blank" rel="noopener">
        {% if v.thumbnail %}
        <img class="thumb" src="{{ v.thumbnail }}" alt="" loading="lazy">
        {% else %}
        <div class="thumb"></div>
        {% endif %}
        <div class="video-meta">
          <span class="video-title">{{ v.title }}</span>
          <div class="video-sub">
            <span class="channel">{{ v.channel }}</span>
            <span>·</span>
            <span>{{ v.published_display }}</span>
          </div>
        </div>
      </a>
      {% endfor %}
    {% else %}
      <p class="empty">Sin videos recientes en esta categoría.</p>
    {% endif %}
    </div>

    <div class="subpanel" id="cat-{{ loop.index }}-canales">
      {% set chans = channels_by_category.get(cat, []) %}
      {% if chans %}
      {% if first_run %}
      <p class="empty" style="margin-bottom:12px;">Esta es la primera ejecución — todavía no hay una comparación anterior para saber qué canales subieron algo nuevo. Eso empezará a verse desde la próxima actualización.</p>
      {% endif %}
      <ul class="channel-list">
        {% for c in chans %}
        <li>
          <span class="channel-item">
            {% if c.logo %}
            <img class="channel-logo" src="{{ c.logo }}" alt="" loading="lazy">
            {% else %}
            <span class="channel-logo channel-logo-fallback">{{ c.title[0]|upper }}</span>
            {% endif %}
            <a href="{{ c.url }}" target="_blank" rel="noopener">{{ c.title }}</a>{% if c.id in channels_with_new_material %}<span class="new-marker" title="Subió contenido nuevo desde la última actualización">*</span>{% endif %}
          </span>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <p class="empty">No hay canales asignados a esta categoría.</p>
      {% endif %}
    </div>
  </section>
  {% endfor %}
</main>

<script>
  const buttons = document.querySelectorAll('.cat-btn');
  const panels = document.querySelectorAll('.panel');
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(btn.dataset.target).classList.add('active');
      window.scrollTo({top:0, behavior:'instant'});
    });
  });

  document.querySelectorAll('.panel').forEach(panel => {
    const subbtns = panel.querySelectorAll('.subtab-btn');
    const subpanels = panel.querySelectorAll('.subpanel');
    subbtns.forEach(btn => {
      btn.addEventListener('click', () => {
        subbtns.forEach(b => b.classList.remove('active'));
        subpanels.forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById(btn.dataset.subtarget).classList.add('active');
      });
    });
  });
</script>

</body>
</html>
